# Example .env file for Breeze Backend

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/breeze

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# JWT Expiration (human-readable format)
JWT_ACCESS_EXPIRES_IN=10m
JWT_REFRESH_EXPIRES_IN=7d

# JWT Expiration in seconds (for calculations)
JWT_ACCESS_EXPIRES_IN_SECONDS=600
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# Cookie Max Age in milliseconds
JWT_ACCESS_COOKIE_MAX_AGE_MS=600000
JWT_REFRESH_COOKIE_MAX_AGE_MS=604800000

# Refresh Session Configuration
JWT_REFRESH_SESSION_ABSOLUTE_LIFETIME_SECONDS=2592000
JWT_REFRESH_REUSE_DETECTION_RETENTION_SECONDS=604800
JWT_STRICT_REFRESH_REUSE_REVOKE_ALL=false

# Redis Configuration (for token blacklist)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Anomaly Detection Configuration
# Enable/disable anomaly detection system
ANOMALY_DETECTION_ENABLED=true

# Access token TTL (seconds) for MEDIUM risk sessions requiring step-up
# Default: 120 seconds (2 minutes)
ANOMALY_STEPUP_ACCESS_TOKEN_TTL=120

# Impossible travel detection threshold (minutes)
# If country changes within this time, flags as impossible travel
# Default: 60 minutes
IMPOSSIBLE_TRAVEL_MINUTES=60

# Rapid refresh detection window (milliseconds)
# Time window to check for suspicious refresh patterns
# Default: 120000ms (2 minutes)
RAPID_REFRESH_WINDOW_MS=120000

# Rapid refresh threshold (count)
# Number of refreshes within the window to trigger alert
# Default: 3 refreshes
RAPID_REFRESH_THRESHOLD=3

# Email Notifications Configuration
# Enable/disable email notifications for security events
EMAIL_ENABLED=false

# SMTP Configuration (required if EMAIL_ENABLED=true)
# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP authentication username (usually your email)
SMTP_USER=your-email@gmail.com

# SMTP authentication password or app-specific password
SMTP_PASS=your-smtp-password

# From address for outgoing emails
SMTP_FROM=noreply@yourapp.com

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Environment
NODE_ENV=development
