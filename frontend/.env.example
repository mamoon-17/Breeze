# Backend API URL — point to your running Breeze NestJS instance.
# Local: http://localhost:3000  ·  Deployed: https://api.your-breeze.com
VITE_API_URL=http://localhost:3000

# Web Push VAPID public key (base64 URL-safe).
# Must match the VAPID_PUBLIC_KEY configured on the backend.
# Generate a pair with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
